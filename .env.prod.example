# Copie para .env.prod e preencha. Use com:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# ATENÇÃO às senhas de banco: não use aspas simples (') nem caracteres reservados
# de URL (@ / : # ? %) — APP_DB_PASSWORD entra numa connection string e os três
# valores são interpolados em SQL pelo prod-roles.sh. Gere com: openssl rand -hex 24

# Senha do superusuário `postgres` do banco (obrigatória).
POSTGRES_PASSWORD=troque-esta-senha

# Senha do role `finledger` usado pela aplicação (obrigatória).
APP_DB_PASSWORD=troque-esta-senha

# Role pessoal de acesso remoto ao banco (opcional — só cria se ambos definidos).
# Criado com BYPASSRLS no primeiro initdb. Acesse via túnel SSH:
#   ssh -N -L 5432:127.0.0.1:5432 root@<ip-da-vps>
#   psql "postgres://igor:<senha>@localhost:5432/finledger"
ADMIN_DB_USERNAME=igor
ADMIN_DB_PASSWORD=

# Segredo de assinatura dos JWT (obrigatório). Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-forte

# E-mail de contato do Let's Encrypt (obrigatório — avisos de expiração).
ACME_EMAIL=seu-email@exemplo.com

# Domínio-base dos tenants: habilita GET /tls/ask, que autoriza o TLS on-demand
# do Caddy a emitir certificado para <slug>.finledger.com.br de tenants ativos.
TLS_BASE_DOMAIN=finledger.com.br

# Integração real com a SEFAZ (emissão/cancelamento de NF-e). Enquanto os
# trâmites burocráticos não saem, deixe false: devoluções marcam a nota com
# "cancelamento pendente" em vez de cancelar de fato.
SEFAZ_INTEGRACAO_ATIVA=false

# Origens permitidas no CORS. Curinga por entrada, separadas por vírgula.
CORS_ALLOWED_ORIGINS=https://finledger.com.br,https://*.finledger.com.br

# 1 = exige que o subdomínio da requisição case com o tenant do token.
TENANT_SUBDOMAIN_ENFORCED=1

# Nível de log.
RUST_LOG=finledger=info,tower_http=info

# Deixe vazio em produção (não semeia o tenant demo admin/admin).
SEED_DEMO_TENANT=

# Superadmin inicial do backoffice (opcional — só cria se ambos definidos).
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=

# Login do Grafana (obrigatório — NÃO fica exposto à internet, só via túnel
# SSH, mas ainda assim não deixe a senha padrão "admin"). Gere com: openssl rand -hex 24
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=troque-esta-senha
