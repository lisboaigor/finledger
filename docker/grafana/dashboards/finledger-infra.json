            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_cpu_usage_percent{container_name=~\"finledger.+\"}",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "id": 11
    },
    {
      "type": "timeseries",
      "title": "Containers — memória",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
