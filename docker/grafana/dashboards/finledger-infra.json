      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_mem_usage{container_name=~\"finledger.+\"}",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "id": 12
    },
    {
      "type": "timeseries",
      "title": "Containers — rede (download)",
      "datasource": {
