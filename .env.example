# Senha do superusuário `postgres` do container (docker-compose faz a substituição).
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://finledger:finledger@localhost:5432/finledger
JWT_SECRET=troque-por-um-segredo-forte-em-producao
RUST_LOG=finledger=info,tower_http=info

# Seeds de desenvolvimento (NÃO habilitar em produção):
# Cria o tenant `demo` com usuário admin/admin no startup do backend.
SEED_DEMO_TENANT=1

# Superadmin do backoffice (http://admin.localhost:3001) — o seed só cria o
# usuário se AMBAS as variáveis estiverem definidas.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin

# Métricas Prometheus (porta separada da API). Padrão: 127.0.0.1:9464 —
# em macOS/Docker Desktop o container do Prometheus alcança o loopback do host.
# Em Linux, use 0.0.0.0:9464 e defina METRICS_TOKEN (Bearer) para proteger.
# METRICS_ADDR=127.0.0.1:9464
# METRICS_TOKEN=

# CORS: lista separada por vírgula de origens permitidas. Aceita curinga `*`.
# Se não definido, o padrão permite apenas localhost:3001 (dev).
# Produção, ex.: CORS_ALLOWED_ORIGINS=https://*.finledger.app
# CORS_ALLOWED_ORIGINS=http://*.localhost:3001,http://localhost:3001

# Token da API da Hostinger — usado pelos MCP servers em .mcp.json (Claude Code).
# Gere em: hPanel → API. Defina no ambiente do shell (não só no .env do backend).
# HOSTINGER_API_TOKEN=
