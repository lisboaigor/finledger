# Config do deploy (scripts/deploy.py). Copie para scripts/.deploy.env e preencha.
# scripts/.deploy.env é gitignorado — não versione usuário/IP da VPS.

# Obrigatório: destino SSH da VPS (usuario@ip ou usuario@host).
VPS_HOST=usuario@ip-da-vps

# Opcionais (o script já traz padrões de produção):
# REMOTE_DIR=/opt/finledger
# COMPOSE_FILE=docker-compose.prod.yml
# ENV_FILE=.env.prod
# PG_CONTAINER=finledger-postgres-1
# HEALTH_URL=https://finledger.com.br/
# FORCE=1          # pula a confirmação
# ALLOW_DIRTY=1    # permite árvore suja
