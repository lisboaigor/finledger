              "raw": "{\n  \"sku\": \"PROD-001\",\n  \"descricao\": \"Filtro de Óleo\",\n  \"ncm\": \"84212300\",\n  \"unidade\": \"UN\",\n  \"preco_custo_centavos\": 1500,\n  \"preco_venda_centavos\": 2500,\n  \"categoria\": \"Filtros\"\n}"
            }
