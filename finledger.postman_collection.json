{
  "info": {
    "name": "Finledger ERP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "produto_id", "value": "" },
    { "key": "cliente_id", "value": "" },
    { "key": "fornecedor_id", "value": "" },
    { "key": "venda_id", "value": "" },
    { "key": "item_id", "value": "" },
    { "key": "orcamento_id", "value": "" },
    { "key": "pedido_id", "value": "" },
    { "key": "conta_id", "value": "" },
    { "key": "nf_id", "value": "" },
    { "key": "usuario_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"senha\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Registrar Usuário",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.usuario_id) { pm.collectionVariables.set('usuario_id', json.usuario_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "url": "{{base_url}}/auth/registrar",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"vendedor1\",\n  \"senha\": \"senha123\",\n  \"roles\": [\"vendedor\"]\n}"
            }
          }
        },
        {
          "name": "Listar Usuários",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": "{{base_url}}/auth/usuarios"
          }
        },
        {
          "name": "Buscar Usuário",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": "{{base_url}}/auth/usuarios/{{usuario_id}}"
          }
        },
        {
          "name": "Alterar Senha",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "url": "{{base_url}}/auth/alterar-senha",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senha_atual\": \"admin\",\n  \"nova_senha\": \"nova_senha123\"\n}"
            }
          }
        },
        {
          "name": "Desativar Usuário",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "url": "{{base_url}}/auth/usuarios/{{usuario_id}}/desativar"
          }
        }
      ]
    },
    {
      "name": "Catálogo",
