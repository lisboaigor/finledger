        {
          "name": "Reativar Produto",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "url": "{{base_url}}/catalogo/produtos/{{produto_id}}/reativar"
          }
        }
      ]
    },
