              "mode": "raw",
              "raw": "{\n  \"sku\": \"PROD-001\",\n  \"descricao\": \"Filtro de Óleo Premium\",\n  \"ncm\": \"84212300\",\n  \"unidade\": \"UN\",\n  \"categoria\": \"Filtros\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Preços",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PUT",
            "url": "{{base_url}}/catalogo/produtos/{{produto_id}}/precos",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preco_custo_centavos\": 1800,\n  \"preco_venda_centavos\": 2900\n}"
            }
          }
        },
        {
          "name": "Desativar Produto",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "url": "{{base_url}}/catalogo/produtos/{{produto_id}}/desativar"
